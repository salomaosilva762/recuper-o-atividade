programa {
  funcao inicio() {
    real n1, n2, n3, media
   escreva("nota 01")
    leia(n1)
escreva("nota 02")
    leia(n2)
escreva("nota 03 ")
    leia(n3)
    media = (n1 + n2 + n3) / 3
    escreva(media, " ")
    se (media >= 6) {
      escreva("Aprovado")
    }
    se (media < 6) {
      escreva("reprovado")
    }
  }
}
