programa {
  funcao inicio() {
    real n1, n2, n3, resultado
    inteiro opcao
    escreva("nota 01 ")
    leia(n1)
escreva("nota 02 ")
    leia(n2)
escreva("nota 03 ")
    leia(n3)
    leia(opcao)
    resultado = 0.0
    se (opcao == 1) {
      resultado = (n1 + n2 + n3) / 3
    }
    se (opcao == 2) {
      resultado = ((n1 * 3) + (n2 * 3) + (n3 * 4)) / 10
    }
    se (opcao == 3) {
      resultado = 3 / ((1/n1) + (1/n2) + (1/n3))
    }
    escreva(resultado)
  }
}
