programa {
  funcao inicio() {
    
    inteiro total_segundos, horas, minutos, segundos
  escreva("quanto tempo durou o evento ?")
   leia(total_segundos)
    horas = total_segundos / 3600
    minutos = (total_segundos % 3600) / 60
    segundos = total_segundos % 60
    escreva(horas, ":", minutos, ":", segundos)
  }
